; Inno Setup 6 Script
; Generated by Installer Generator — do not edit manually.
; Regenerate: python -m installer → Build Installer
; https://jrsoftware.org/isinfo.php
;
; NOTE: Template uses custom delimiters (double brackets / percent-brackets)
;       for Jinja2 directives so that Inno Setup's own {…} constants pass through unchanged.

#define AppName      "[[ c.app.name ]]"
#define AppVersion   "[[ c.app.version ]]"
#define AppPublisher "[[ c.app.publisher ]]"
#define AppExeName   "[[ c.app.exe_name ]]"

[Setup]
AppId={{[[ c.app.app_id ]]}}
AppName={#AppName}
AppVersion={#AppVersion}
AppVerName={#AppName} {#AppVersion}
AppPublisher={#AppPublisher}
DefaultDirName=[[ c.paths.default_install_dir.replace('{pf}', '{autopf}') ]]
DefaultGroupName=[[ c.shortcuts.start_menu_folder ]]
[% if c.app.license_file %]LicenseFile=[[ c.app.license_file ]][% endif %]
[% if c.app.icon %]SetupIconFile=[[ c.app.icon ]][% endif %]
OutputDir=[[ c.paths.output_dir ]]
OutputBaseFilename=[[ c.app.name ]]_[[ c.app.version ]]_Setup
Compression=lzma2/ultra64
SolidCompression=yes
WizardStyle=modern
[% if icon_name %]UninstallDisplayIcon={app}\[[ icon_name ]]
[% else %]UninstallDisplayIcon={app}\{#AppExeName}
[% endif %]
MinVersion=10.0
PrivilegesRequired=admin
[% if c.installer.log_install %]SetupLogging=yes[% endif %]

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Tasks]
[% if c.shortcuts.desktop %]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked
[% endif %]

[Files]
; Recursively include everything from the packaged application directory
Source: "[[ c.paths.source_dir ]]\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs
[% if icon_file %]
; App icon — copied into install dir so shortcuts can reference it directly
Source: "[[ icon_file ]]"; DestDir: "{app}"; Flags: ignoreversion
[% endif %]

[Icons]
[% if icon_name %]
Name: "{group}\{#AppName}"; Filename: "{app}\{#AppExeName}"; IconFilename: "{app}\[[ icon_name ]]"
Name: "{group}\{cm:UninstallProgram,{#AppName}}"; Filename: "{uninstallexe}"
[% if c.shortcuts.desktop %]
Name: "{autodesktop}\{#AppName}"; Filename: "{app}\{#AppExeName}"; IconFilename: "{app}\[[ icon_name ]]"; Tasks: desktopicon
[% endif %]
[% else %]
Name: "{group}\{#AppName}"; Filename: "{app}\{#AppExeName}"
Name: "{group}\{cm:UninstallProgram,{#AppName}}"; Filename: "{uninstallexe}"
[% if c.shortcuts.desktop %]
Name: "{autodesktop}\{#AppName}"; Filename: "{app}\{#AppExeName}"; Tasks: desktopicon
[% endif %]
[% endif %]

[Run]
Filename: "{app}\{#AppExeName}"; Description: "{cm:LaunchProgram,{#StringChange(AppName, '&', '&&')}}"; Flags: nowait postinstall skipifsilent

; Silent install: pass /SILENT or /VERYSILENT on the command line
; Logging:        pass /LOG=<path> to capture install log to a file

[% if c.update.enabled %]
; ── Auto-updater config written to the install directory at install time ──────
[Code]
procedure CurStepChanged(CurStep: TSetupStep);
var
  ConfigPath: String;
  Lines: TStringList;
begin
  if CurStep = ssPostInstall then
  begin
    ConfigPath := ExpandConstant('{app}\updater_config.json');
    Lines := TStringList.Create;
    try
      Lines.Add('{');
      Lines.Add('  "enabled": true,');
      Lines.Add('  "current_version": "{#AppVersion}",');
      Lines.Add('  "github_repo": "[[ c.update.github_repo ]]",');
      Lines.Add('  "github_asset_pattern": "[[ c.update.github_asset_pattern ]]",');
      Lines.Add('  "check_url": "[[ c.update.check_url ]]",');
      Lines.Add('  "interval_hours": [[ c.update.interval_hours ]],');
      Lines.Add('  "verify_checksum": [[ "true" if c.update.verify_checksum else "false" ]],');
      Lines.Add('  "verify_signature": [[ "true" if c.update.verify_signature else "false" ]]');
      Lines.Add('}');
      Lines.SaveToFile(ConfigPath);
    finally
      Lines.Free;
    end;
  end;
end;
[% endif %]
