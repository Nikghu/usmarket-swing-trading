; NSIS Script (NullSoft Scriptable Install System)
; Generated by Installer Generator — do not edit manually.
; Regenerate: python -m installer → Build Installer
; https://nsis.sourceforge.io/
;
; NOTE: Template uses [[ ]] / [% %] for Jinja2 directives so that
;       NSIS's own ${…} variables pass through unchanged.

!include "MUI2.nsh"
!include "LogicLib.nsh"

; ── Metadata ──────────────────────────────────────────────────────────────────
Name              "[[ c.app.name ]]"
OutFile           "[[ c.paths.output_dir ]][[ c.app.name ]]_[[ c.app.version ]]_Setup.exe"
InstallDir        "$PROGRAMFILES64\[[ c.app.name ]]"
InstallDirRegKey  HKLM "Software\[[ c.app.publisher ]]\[[ c.app.name ]]" "InstallPath"
RequestExecutionLevel admin

VIProductVersion  "[[ c.app.version ]].0"
VIAddVersionKey "ProductName"   "[[ c.app.name ]]"
VIAddVersionKey "CompanyName"   "[[ c.app.publisher ]]"
VIAddVersionKey "FileVersion"   "[[ c.app.version ]]"
VIAddVersionKey "ProductVersion" "[[ c.app.version ]]"
VIAddVersionKey "LegalCopyright" "© [[ c.app.publisher ]]"

; ── MUI Pages ─────────────────────────────────────────────────────────────────
[% if c.app.icon %]!define MUI_ICON "[[ c.app.icon ]]"[% endif %]
[% if c.installer.log_install %]!define MUI_INSTFILESPAGE_SHOWDETAILS[% endif %]

[% if c.app.license_file %]!insertmacro MUI_PAGE_LICENSE "[[ c.app.license_file ]]"[% endif %]
!insertmacro MUI_PAGE_DIRECTORY
!insertmacro MUI_PAGE_INSTFILES
!insertmacro MUI_PAGE_FINISH

!insertmacro MUI_UNPAGE_CONFIRM
!insertmacro MUI_UNPAGE_INSTFILES

!insertmacro MUI_LANGUAGE "English"

; ── Install Section ───────────────────────────────────────────────────────────
Section "MainSection" SEC01
  SetOutPath "$INSTDIR"
  File /r "[[ c.paths.source_dir ]]*.*"

  ; Registry entries
  WriteRegStr HKLM "Software\[[ c.app.publisher ]]\[[ c.app.name ]]" "InstallPath" "$INSTDIR"
  WriteRegStr HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\[[ c.app.name ]]" \
    "DisplayName"    "[[ c.app.name ]]"
  WriteRegStr HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\[[ c.app.name ]]" \
    "DisplayVersion" "[[ c.app.version ]]"
  WriteRegStr HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\[[ c.app.name ]]" \
    "Publisher"      "[[ c.app.publisher ]]"
  WriteRegStr HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\[[ c.app.name ]]" \
    "UninstallString" "$INSTDIR\Uninstall.exe"

  WriteUninstaller "$INSTDIR\Uninstall.exe"

  [% if c.shortcuts.start_menu %]
  CreateDirectory "$SMPROGRAMS\[[ c.shortcuts.start_menu_folder ]]"
  CreateShortcut  "$SMPROGRAMS\[[ c.shortcuts.start_menu_folder ]]\[[ c.app.name ]].lnk" \
                  "$INSTDIR\[[ c.app.exe_name ]]"
  CreateShortcut  "$SMPROGRAMS\[[ c.shortcuts.start_menu_folder ]]\Uninstall [[ c.app.name ]].lnk" \
                  "$INSTDIR\Uninstall.exe"
  [% endif %]
  [% if c.shortcuts.desktop %]
  CreateShortcut "$DESKTOP\[[ c.app.name ]].lnk" "$INSTDIR\[[ c.app.exe_name ]]"
  [% endif %]

  [% if c.update.enabled %]
  ; Write updater config so the bundled updater_stub.py knows where to check
  FileOpen  $0 "$INSTDIR\updater_config.json" w
  FileWrite $0 '{$\n'
  FileWrite $0 '  "enabled": true,$\n'
  FileWrite $0 '  "current_version": "[[ c.app.version ]]",$\n'
  FileWrite $0 '  "github_repo": "[[ c.update.github_repo ]]",$\n'
  FileWrite $0 '  "github_asset_pattern": "[[ c.update.github_asset_pattern ]]",$\n'
  FileWrite $0 '  "check_url": "[[ c.update.check_url ]]",$\n'
  FileWrite $0 '  "interval_hours": [[ c.update.interval_hours ]],$\n'
  FileWrite $0 '  "verify_checksum": [[ "true" if c.update.verify_checksum else "false" ]],$\n'
  FileWrite $0 '  "verify_signature": [[ "true" if c.update.verify_signature else "false" ]]$\n'
  FileWrite $0 '}$\n'
  FileClose $0
  [% endif %]
SectionEnd

; ── Uninstall Section ─────────────────────────────────────────────────────────
Section "Uninstall"
  RMDir /r "$INSTDIR"

  [% if c.shortcuts.start_menu %]
  RMDir /r "$SMPROGRAMS\[[ c.shortcuts.start_menu_folder ]]"
  [% endif %]
  [% if c.shortcuts.desktop %]
  Delete "$DESKTOP\[[ c.app.name ]].lnk"
  [% endif %]

  DeleteRegKey HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\[[ c.app.name ]]"
  DeleteRegKey HKLM "Software\[[ c.app.publisher ]]\[[ c.app.name ]]"
SectionEnd
